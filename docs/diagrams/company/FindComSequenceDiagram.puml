@startuml
title Sequence Diagram: findcom

actor User
participant ":LogicManager" as Logic
participant ":AddressBookParser" as ABParser
participant ":FindComCommandParser" as Parser
participant "f:FindComCommand" as Command
participant "m:Model" as Model

User -> Logic : execute("findcom Google; Amazon")
Logic -> ABParser : parseCommand("findcom Google; Amazon")
ABParser -> Parser : parse("Google; Amazon")
Parser --> ABParser : FindComCommand
ABParser --> Logic : FindComCommand

Logic -> Command : execute(model)
Command -> Model : updateFilteredPersonList(predicate)
Model --> Command
Command --> Logic : CommandResult
Logic --> User : CommandResult

@enduml