@startuml
participant "LogicManager" as LogicManager
participant "TagUnassignCommand" as TagUnassignCommand
participant "Model" as Model

-> LogicManager : execute("tag unassign ...")
activate LogicManager

LogicManager -> TagUnassignCommand : execute(model)
activate TagUnassignCommand

TagUnassignCommand -> Model : getFilteredPersonList()
activate Model
Model --> TagUnassignCommand : personList
deactivate Model

loop validate indexes
    TagUnassignCommand -> Model : getFilteredPersonList()
    activate Model
    Model --> TagUnassignCommand : personList
    deactivate Model

    alt invalid index
        TagUnassignCommand --> LogicManager : CommandException
    end
end

loop check tag assigned
    TagUnassignCommand -> Model : getFilteredPersonList()
    activate Model
    Model --> TagUnassignCommand : personList
    deactivate Model

    alt tag not assigned
        TagUnassignCommand --> LogicManager : CommandException
    end
end

loop remove tag from persons
    TagUnassignCommand -> Model : setPerson(personToEdit, editedPerson)
    activate Model
    Model --> TagUnassignCommand
    deactivate Model
end

TagUnassignCommand -> Model : updateFilteredPersonList(PREDICATE_SHOW_ALL_PERSONS)
activate Model
Model --> TagUnassignCommand
deactivate Model

TagUnassignCommand --> LogicManager : CommandResult

deactivate TagUnassignCommand
<-- LogicManager
deactivate LogicManager
@enduml
